<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MySmart" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#0A84FF</item>
        <item name="colorPrimaryVariant">#007AFF</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#30D158</item>
        <item name="colorSecondaryVariant">#25A244</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">#F2F2F7</item>
        <item name="colorOnSurface">#1C1C1E</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
        <!-- Card style -->
        <item name="materialCardViewStyle">@style/GlassCardStyle</item>
    </style>

    <style name="GlassCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/glass_bg_light</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>

